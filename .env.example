# Server
PORT=3001
NODE_ENV=development

# Session (REQUIRED — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=iota_place
POSTGRES_USER=iota_place
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Payment
PAYMENT_MODE=mock
# IOTA (only used when PAYMENT_MODE=iota)
IOTA_NETWORK=testnet
IOTA_COLLECTION_ADDRESS=

# Admin (use a strong password, min 12 characters)
ADMIN_PASSWORD=CHANGE_ME_use_a_strong_random_password
ADMIN_WALLETS=

# CORS
CLIENT_URL=http://localhost:5173
